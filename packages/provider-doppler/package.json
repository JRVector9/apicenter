{
  "name": "@apicenter/provider-doppler",
  "version": "0.3.0",
  "description": "Doppler provider adapter for apicenter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
