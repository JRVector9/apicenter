  "keywords": ["apicenter", "doppler", "secrets", "provider"],
  "license": "MIT",
  "dependencies": {
    "@apicenter/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
